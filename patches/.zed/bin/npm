#!/data/data/com.zdroid/files/usr/bin/sh
# Auto-generated by gpui_android termux_bootstrap. Forwards to real
# npm and fires the launcher generator on success so newly-installed
# CLI tools get the right runtime wrapper (proot for static binaries
# with hardcoded Linux paths, otherwise direct exec via npm's own
# symlink). Self-healing — re-installed at every boot.
REAL_NPM_JS=/data/data/com.zdroid/files/usr/lib/node_modules/npm/bin/npm-cli.js
NODE=/data/data/com.zdroid/files/usr/bin/node
HOOK=/data/data/com.zdroid/files/usr/etc/apt/zed-launcher-gen.sh
TERMUX_EXEC=/data/data/com.zdroid/files/usr/lib/libtermux-exec.so
# Set LD_PRELOAD only inside this wrapper's process tree so
# libtermux-exec.so intercepts execve and rewrites Linux-style
# shebangs (#!/usr/bin/env node, #!/bin/sh, etc.) to their
# Termux equivalents at $PREFIX/bin/. Without this, every
# `npm run-script` that exec's a node-shebang'd CLI in
# `node_modules/.bin/` (tsc, eslint, prettier, etc.) fails
# with `sh: 1: tsc: not found` — the kernel binfmt_script
# reports the SHEBANG file (/usr/bin/env) as missing rather
# than the script itself. The gpui app process REMOVES
# LD_PRELOAD globally at boot to keep ssh subprocesses clean
# of `cannot be preloaded` spam on remote shells (see L10
# phase doc Section D); scoping it to just npm here avoids
# both regressions.
if [ ! -x "$NODE" ] || [ ! -f "$REAL_NPM_JS" ]; then
    echo "zed-npm: real npm or node missing" >&2
    exit 1
fi
if [ -f "$TERMUX_EXEC" ]; then
    export LD_PRELOAD="$TERMUX_EXEC"
fi
# Force npm to pick `musl` libc variants of platform-specific
# optional deps. Termux's bionic isn't detected as glibc OR
# musl by npm's detect-libc (returns null), and packages like
# @anthropic-ai/claude-code with `engines.libc: musl` in the
# optional dep's package.json get silently skipped — install
# appears to succeed but the native binary is missing.
# `--libc=musl` (via env) tells npm to pick the musl variant;
# our $PREFIX/lib/ld-musl-aarch64.so.1 + launcher-gen handle
# the runtime side. Same flag set in node_runtime crate for
# Zed-driven npm installs.
export npm_config_libc=musl
"$NODE" "$REAL_NPM_JS" "$@"
RC=$?
if [ -x "$HOOK" ]; then
    "$HOOK" 2>&1 || true
fi
exit $RC
